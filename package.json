{
  "name": "securepay-ai",
  "version": "1.0.0",
  "private": true,
  "description": "SecurePay AI - UPI QR Fraud Detection System",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run client:dev & npm run server:dev",
    "dev:client": "cd client && npm run dev",
    "dev:server": "cd server && npm run dev",
    "build": "npm run client:build && npm run server:build",
    "build:client": "cd client && npm run build",
    "build:server": "cd server && npm run build",
    "install:all": "npm install && cd client && npm install && cd ../server && npm install",
    "test": "npm run test:client && npm run test:server",
    "test:client": "cd client && npm test",
    "test:server": "cd server && npm test"
  },
  "keywords": [
    "upi",
    "qr-code",
    "fraud-detection",
    "security",
    "ai",
    "react",
    "node.js",
    "mongodb"
  ],
  "author": "Your Name",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/securepay-ai.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/securepay-ai/issues"
  },
  "homepage": "https://github.com/yourusername/securepay-ai#readme",
  "dependencies": {
    "axios": "^1.13.6",
    "jsqr": "^1.4.0",
    "react-qr-reader": "^3.0.0-beta-1"
  }
}
